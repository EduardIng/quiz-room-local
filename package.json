{
  "name": "quiz-room-local",
  "version": "0.2.0",
  "description": "Local kiosk quiz system — tablet podiums, LAN-only, auto-reconnect",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "test": "jest --forceExit",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [
    "quiz",
    "trivia",
    "websocket",
    "kiosk",
    "lan",
    "local"
  ],
  "author": "EduardIng",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "clearMocks": true
  }
}
